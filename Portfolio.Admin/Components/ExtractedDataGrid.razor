@using Portfolio.Admin.Models
@using BlazorBlueprint.Components

<BbCard Class="h-full">
    <BbCardHeader>
        <BbCardTitle>Extracted PO Data</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        <div class="relative w-full overflow-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
                        <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">PO Number</th>
                        <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Vendor Name</th>
                        <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Date</th>
                        <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Item Name</th>
                        <th class="h-12 px-4 text-right align-middle font-medium text-muted-foreground">Qty</th>
                        <th class="h-12 px-4 text-right align-middle font-medium text-muted-foreground">Price</th>
                        <th class="h-12 px-4 text-right align-middle font-medium text-muted-foreground">Amount</th>
                    </tr>
                </thead>
                <tbody class="[&_tr:last-child]:border-0">
                    @foreach (var item in _mockData)
                    {
                        <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
                            <td class="p-4 align-middle font-medium">@item.PoNumber</td>
                            <td class="p-4 align-middle">@item.VendorName</td>
                            <td class="p-4 align-middle text-muted-foreground">@item.Date.ToShortDateString()</td>
                            <td class="p-4 align-middle">@item.ItemName</td>
                            <td class="p-4 align-middle text-right">@item.Quantity</td>
                            <td class="p-4 align-middle text-right">@item.UnitPrice.ToString("C")</td>
                            <td class="p-4 align-middle text-right font-medium text-primary">@item.Amount.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </BbCardContent>
</BbCard>

@code {
    private List<PoData> _mockData = new()
    {
        new PoData { PoNumber = "PO-2026-001", VendorName = "TechCorp Inc.", Date = new DateTime(2026, 4, 25), ItemName = "MacBook Pro 16\"", Quantity = 2, UnitPrice = 2499.00m, Amount = 4998.00m },
        new PoData { PoNumber = "PO-2026-001", VendorName = "TechCorp Inc.", Date = new DateTime(2026, 4, 25), ItemName = "Magic Mouse", Quantity = 2, UnitPrice = 79.00m, Amount = 158.00m },
        new PoData { PoNumber = "PO-2026-002", VendorName = "Office Supplies Co.", Date = new DateTime(2026, 4, 28), ItemName = "Ergonomic Chair", Quantity = 5, UnitPrice = 350.00m, Amount = 1750.00m },
        new PoData { PoNumber = "PO-2026-003", VendorName = "Cloud Systems LLC", Date = new DateTime(2026, 4, 30), ItemName = "Server Rack", Quantity = 1, UnitPrice = 1200.00m, Amount = 1200.00m }
    };
}
