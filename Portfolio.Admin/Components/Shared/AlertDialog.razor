@inject NavigationManager Navigation

@if (Visible)
{
    <div class="alert-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.6); display: flex; justify-content: center; align-items: center; z-index: 9999;">
        <BbCard Class="w-full max-w-sm p-6 flex flex-col gap-6 shadow-xl">
            <div class="alert-message @Type" style="color: var(--foreground); font-weight: 500; font-size: 1.1rem; text-align: center;">
                @Message
            </div>

            <div style="display: flex; justify-content: center; gap: 0.75rem;">
                @if (ShowCancel)
                {
                    <BbButton Variant="ButtonVariant.Outline" OnClick="() => CloseDialog(false)">
                        Cancel
                    </BbButton>
                }
                <BbButton Variant="ButtonVariant.Default" OnClick="() => CloseDialog(true)">
                    OK
                </BbButton>
            </div>
        </BbCard>
    </div>
}

@code {

    [Parameter]
    public string Message { get; set; } = "";

    [Parameter]
    public string Type { get; set; } = "success";

    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public bool ShowCancel { get; set; } = false;

    [Parameter]
    public EventCallback<bool> OnClose { get; set; }

    private async Task CloseDialog(bool result)
    {
        await OnClose.InvokeAsync(result);
        Navigation.NavigateTo("/");
    }

}