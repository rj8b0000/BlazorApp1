@inject IJSRuntime JSRuntime

<div class="card" style="height: 100%; display: flex; flex-direction: column;">
    <div class="card-header" style="flex: 0 0 auto; display: flex; justify-content: space-between; align-items: center;">
        <h3 class="card-title">Document Preview</h3>
        <div>
            <InputFile id="pdf-upload" OnChange="HandlePdfUpload" accept=".pdf" style="display: none;" />
            <label for="pdf-upload" class="btn-primary btn-action bg-primary" style="cursor: pointer; margin: 0;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                Upload PDF
            </label>
        </div>
    </div>
    
    <div style="flex: 1 1 auto; overflow: hidden; position: relative;">
        @if (!string.IsNullOrEmpty(_pdfObjectUrl))
        {
            <iframe id="pdf-iframe" src="/pdfjs/web/viewer.html?file=@(_pdfObjectUrl)" style="width: 100%; height: 100%; border: none;"></iframe>
        }
        else
        {
            <div class="state-container" style="height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                <svg class="state-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                <h3 class="state-title">No Document Selected</h3>
                <p>Upload a PDF file to preview it here.</p>
            </div>
        }
    </div>
</div>

<script>
    window.createObjectUrl = function(bytes, contentType) {
        const blob = new Blob([new Uint8Array(bytes)], { type: contentType });
        return URL.createObjectURL(blob);
    };
    
    window.updatePdfIframe = function(url) {
        const iframe = document.getElementById('pdf-iframe');
        if (iframe && iframe.contentWindow && iframe.contentWindow.PDFViewerApplication) {
            iframe.contentWindow.PDFViewerApplication.open({ url: url });
        }
    }
</script>

@code {
    private string _pdfObjectUrl = "";

    private async Task HandlePdfUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && file.ContentType == "application/pdf")
        {
            try
            {
                // Increase max allowed size if needed (currently set to 10MB)
                using var stream = file.OpenReadStream(10 * 1024 * 1024);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                var bytes = memoryStream.ToArray();

                // Create object URL from byte array
                var newUrl = await JSRuntime.InvokeAsync<string>("window.createObjectUrl", bytes, file.ContentType);
                
                if (string.IsNullOrEmpty(_pdfObjectUrl)) {
                    _pdfObjectUrl = newUrl;
                    StateHasChanged();
                } else {
                    _pdfObjectUrl = newUrl;
                    // If iframe is already there, update it dynamically to prevent full reload
                    await JSRuntime.InvokeVoidAsync("window.updatePdfIframe", _pdfObjectUrl);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error uploading file: {ex.Message}");
            }
        }
    }
}
