@inject IJSRuntime JSRuntime
@using BlazorBlueprint.Components

<BbCard Class="h-full flex flex-col">
    <BbCardHeader>
        <div class="flex justify-between items-center w-full">
            <BbCardTitle>Document Preview</BbCardTitle>
            <div>
                <InputFile id="pdf-upload-input"
                           OnChange="HandlePdfUpload"
                           accept=".pdf"
                           style="display:none" />

                @* Using standard HTML button with BbButton styling for maximum reliability *@
                <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-10 py-2 px-4"
                        onclick="document.getElementById('pdf-upload-input').click()">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         width="16"
                         height="16"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="mr-2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="17 8 12 3 7 8"></polyline>
                        <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    Upload PDF
                </button>
            </div>
        </div>
    </BbCardHeader>
    
    <BbCardContent Class="flex-1 p-0 overflow-hidden relative min-h-[500px]">
        @if (!string.IsNullOrEmpty(_pdfObjectUrl))
        {
            <iframe id="pdf-iframe" src="/pdfjs/web/viewer.html?file=@(_pdfObjectUrl)" class="w-full h-full border-none"></iframe>
        }
        else
        {
            <div class="flex flex-col justify-center items-center h-full text-center p-12">
                <div class="bg-muted rounded-full p-4 mb-4">
                    <svg class="text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                </div>
                <h3 class="text-lg font-semibold mb-2">No Document Selected</h3>
                <p class="text-muted-foreground">Upload a PDF file to preview it here.</p>
            </div>
        }
    </BbCardContent>
</BbCard>

<script>
    if (typeof window.createObjectUrl === 'undefined') {
        window.createObjectUrl = function(bytes, contentType) {
            const blob = new Blob([new Uint8Array(bytes)], { type: contentType });
            return URL.createObjectURL(blob);
        };
    }
</script>

@code {
    private string _pdfObjectUrl = string.Empty;

    private async Task HandlePdfUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
            return;

        if (file.ContentType != "application/pdf")
        {
            Console.WriteLine("Only PDF files are allowed.");
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();

            var newUrl = await JSRuntime.InvokeAsync<string>(
                "createObjectUrl",
                bytes,
                file.ContentType
            );

            if (!string.IsNullOrWhiteSpace(_pdfObjectUrl))
            {
                await JSRuntime.InvokeVoidAsync("URL.revokeObjectURL", _pdfObjectUrl);
            }

            _pdfObjectUrl = newUrl;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error uploading PDF: {ex.Message}");
        }
    }
}
