@using Portfolio.Admin.Models.Blog
@inject NavigationManager Navigation

<EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="BlogCreateForm" method="post">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">General Information</h3>
        </div>
        <div class="card-body form-section">
            <div class="form-group">
                <label class="form-label">Title</label>
                <InputText @bind-Value="Model.Title" class="form-control" placeholder="Enter an engaging title..." />
            </div>
            
            <div class="form-group">
                <label class="form-label">Short Description</label>
                <InputText @bind-Value="Model.ShortDescription" class="form-control" placeholder="A brief summary for the preview..." />
            </div>
            
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Tags</label>
                <InputText @bind-Value="Model.Tags" class="form-control" placeholder="e.g. C#, Blazor, WebDev" />
            </div>
        </div>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Content</h3>
        </div>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">HTML Content</label>
                <Portfolio.Admin.Components.Shared.RichTextEditor @bind-Value="Model.HtmlContent" />
            </div>
        </div>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Media & Publishing</h3>
        </div>
        <div class="card-body form-section">
            <div class="form-group">
                <label class="form-label">Cover Image</label>
                <InputFile OnChange="HandleFileChange" class="form-control" style="padding: 0.375rem 0.5rem;" />
            </div>
            
            <div class="form-group" style="flex-direction: row; align-items: center; gap: 0.75rem; margin-top: 1.5rem;">
                <InputCheckbox @bind-Value="Model.IsPublished" id="isPublished" />
                <label for="isPublished" class="form-label" style="margin-bottom: 0;">Publish immediately</label>
            </div>
        </div>
    </div>
    
    <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-bottom: 2rem;">
        <button type="button" class="btn-action" style="border: 1px solid var(--border-color); color: var(--text-color); padding: 0.5rem 1rem; border-radius: 6px;" @onclick="Cancel">
            Cancel
        </button>
        <button type="submit" disabled="@IsSubmitting" class="btn-primary" style="display: flex; align-items: center; gap: 0.5rem;">
            @if (IsSubmitting)
            {
                <div class="spinner" style="width: 16px; height: 16px; border-width: 2px; margin: 0;"></div>
                <span>Saving...</span>
            }
            else
            {
                <span>Save Blog Post</span>
            }
        </button>
    </div>
</EditForm>

@code {
    [Parameter] public CreateBlogRequest Model { get; set; } = new();
    [Parameter] public EventCallback<CreateBlogRequest> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync(Model);
    }

    private void HandleFileChange(InputFileChangeEventArgs e)
    {
        Model.CoverImage = e.File;
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/blog");
    }
}