@using Portfolio.Admin.Models.Blog
@inject NavigationManager Navigation

<EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="BlogCreateForm" method="post">
    <BbCard Class="mb-6">
        <BbCardHeader>
            <BbCardTitle>General Information</BbCardTitle>
        </BbCardHeader>
        <BbCardContent Class="grid gap-6">
            <div class="grid gap-2">
                <label class="text-sm font-medium">Title</label>
                <BbInput @bind-Value="Model.Title" Placeholder="Enter an engaging title..." />
            </div>
            
            <div class="grid gap-2">
                <label class="text-sm font-medium">Short Description</label>
                <BbInput @bind-Value="Model.ShortDescription" Placeholder="A brief summary for the preview..." />
            </div>
            
            <div class="grid gap-2">
                <label class="text-sm font-medium">Tags</label>
                <BbInput @bind-Value="Model.Tags" Placeholder="e.g. C#, Blazor, WebDev" />
            </div>
        </BbCardContent>
    </BbCard>
    
    <BbCard Class="mb-6">
        <BbCardHeader>
            <BbCardTitle>Content</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="grid gap-2">
                <label class="text-sm font-medium">HTML Content</label>
                <Portfolio.Admin.Components.Shared.RichTextEditor @bind-Value="Model.HtmlContent" />
            </div>
        </BbCardContent>
    </BbCard>
    
    <BbCard Class="mb-6">
        <BbCardHeader>
            <BbCardTitle>Media & Publishing</BbCardTitle>
        </BbCardHeader>
        <BbCardContent Class="grid gap-6">
            @if (!string.IsNullOrEmpty(ExistingImageUrl))
            {
                <div class="grid gap-2">
                    <label class="text-sm font-medium">Current Cover Image</label>
                    <img src="@ExistingImageUrl" alt="Cover Image" class="max-h-48 rounded-md border object-cover" />
                </div>
            }
            
            <div class="grid gap-2">
                <label class="text-sm font-medium">@(string.IsNullOrEmpty(ExistingImageUrl) ? "Cover Image" : "Upload New Cover Image")</label>
                <InputFile OnChange="HandleFileChange" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
            </div>
            
            <div class="flex items-center space-x-2">
                <BbCheckbox @bind-Checked="Model.IsPublished" Id="isPublished" />
                <label for="isPublished" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-opacity-70">Publish immediately</label>
            </div>
        </BbCardContent>
    </BbCard>
    
    <div class="flex justify-end space-x-4 mb-8">
        <BbButton Variant="ButtonVariant.Outline" OnClick="Cancel">Cancel</BbButton>
        <BbButton Variant="ButtonVariant.Default" OnClick="HandleSubmit" Disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <div class="mr-2 h-4 w-4 animate-spin rounded-full border-2 border-primary border-t-transparent"></div>
                <span>Saving...</span>
            }
            else
            {
                <span>Save Blog Post</span>
            }
        </BbButton>
    </div>
</EditForm>

@code {
    [Parameter] public CreateBlogRequest Model { get; set; } = new();
    [Parameter] public EventCallback<CreateBlogRequest> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string ExistingImageUrl { get; set; }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync(Model);
    }

    private void HandleFileChange(InputFileChangeEventArgs e)
    {
        Model.CoverImage = e.File;
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }
}