@page "/pdf-analysis"
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="page-header">
    <div class="page-header-info">
        <div class="breadcrumb">
            <a href="">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <span>Document Analysis</span>
        </div>
        <h2 class="page-title">PDF Analysis</h2>
    </div>
</div>

<div class="pdf-analysis-container" style="--left-width: 50%;">
    <div class="pdf-panel">
        <PdfViewerPanel />
    </div>
    
    <div class="splitter" @onmousedown="() => {}">
        <div class="splitter-handle"></div>
    </div>
    
    <div class="data-panel">
        <ExtractedDataGrid />
    </div>
</div>



<style>
    .pdf-analysis-container {
        display: flex;
        flex-direction: row;
        height: calc(100vh - 160px); /* Adjust based on your header/padding */
        min-height: 600px;
        width: 100%;
    }
    
    .pdf-panel {
        width: var(--left-width);
        height: 100%;
        min-width: 0;
    }

    .splitter {
        width: 12px;
        height: 100%;
        cursor: col-resize;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: transparent;
        transition: background-color 0.2s;
        z-index: 10;
        margin: 0 4px;
    }
    
    .splitter:hover, .splitter:active {
        background-color: #e2e8f0; /* hover color */
    }

    .splitter-handle {
        width: 4px;
        height: 32px;
        background-color: #cbd5e1;
        border-radius: 2px;
    }
    
    .splitter:hover .splitter-handle {
        background-color: #94a3b8;
    }

    .data-panel {
        flex: 1;
        height: 100%;
        min-width: 0;
    }

    /* Responsive adjustment for smaller screens */
    @@media (max-width: 992px) {
        .pdf-analysis-container {
            flex-direction: column;
            height: auto;
        }
        .pdf-panel {
            width: 100% !important;
            height: 60vh;
            min-height: 500px;
        }
        .splitter {
            display: none; /* Hide splitter on mobile */
        }
        .data-panel {
            width: 100%;
            height: auto;
            min-height: 500px;
            margin-top: 20px;
        }
    }
</style>

@code {
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/PdfAnalysis.razor.js");
            await _module.InvokeVoidAsync("initSplitter");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.DisposeAsync();
        }
    }
}
