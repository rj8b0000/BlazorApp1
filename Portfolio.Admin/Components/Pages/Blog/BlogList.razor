@page "/"

@using Portfolio.Admin.Models.Blog
@using Portfolio.Admin.Components.Shared
@using Portfolio.Admin.Services
@using BlazorBlueprint.Components

@inject BlogApiService BlogService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-header-info">
        <div class="breadcrumb">
            <a href="">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <span>Blogs</span>
        </div>
        <h2 class="page-title">Blog Management</h2>
    </div>
    <BbButton Variant="ButtonVariant.Default" OnClick="CreateNewBlog">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Create New
    </BbButton>
</div>

<BbCard>
    <div style="padding: 1rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 300px; max-width: 400px;">
            <BbInput @bind-Value="_searchText" Placeholder="Search blog posts..." />
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <BbButton Variant="ButtonVariant.Outline">Filter</BbButton>
            <BbButton Variant="ButtonVariant.Outline">Export</BbButton>
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b transition-colors hover:bg-muted/50">
                    <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Title</th>
                    <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Status</th>
                    <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Created At</th>
                    <th class="h-12 px-4 text-right align-middle font-medium text-muted-foreground">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr>
                        <td colspan="4" class="p-8 text-center">
                            <div class="spinner" style="width: 24px; height: 24px; margin: 0 auto 1rem auto;"></div>
                            <p class="text-muted-foreground">Loading blogs...</p>
                        </td>
                    </tr>
                }
                else if (!_blogs.Any())
                {
                    <tr>
                        <td colspan="4" class="p-8 text-center text-muted-foreground">
                            No blog posts found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var blog in _blogs)
                    {
                        <tr class="border-b transition-colors hover:bg-muted/50">
                            <td class="p-4 align-middle">
                                <div style="display: flex; flex-direction: column;">
                                    <span style="font-weight: 500; color: var(--foreground);">@blog.Title</span>
                                    <span style="font-size: 0.75rem; color: var(--muted-foreground); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@blog.ShortDescription</span>
                                </div>
                            </td>
                            <td class="p-4 align-middle">
                                @if (blog.IsPublished)
                                {
                                    <span class="badge badge-success">Published</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">Draft</span>
                                }
                            </td>
                            <td class="p-4 align-middle text-muted-foreground">@blog.CreatedAt.ToShortDateString()</td>
                            <td class="p-4 align-middle">
                                <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                    <BbButton Variant="ButtonVariant.Outline" OnClick="() => ViewBlog(blog.Id)">View</BbButton>
                                    <BbButton Variant="ButtonVariant.Secondary" OnClick="() => EditBlog(blog.Id)">Edit</BbButton>
                                    <BbButton Variant="ButtonVariant.Destructive" OnClick="() => ConfirmDelete(blog.Id)">Delete</BbButton>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</BbCard>

<AlertDialog Message="@_message" 
             Type="@_messageType" 
             Visible="@_showDialog" 
             ShowCancel="@_showCancel"
             OnClose="HandleDialogClose" />

@code {

    private List<BlogResponse> _blogs = new();
    private string _searchText = "";

    private bool _loading = true;

    private bool _showDialog = false;
    private bool _showCancel = false;
    private string _message = "";
    private string _messageType = "success";
    private Guid? _blogToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadBlogs();
    }

    private async Task LoadBlogs()
    {
        try
        {
            _loading = true;
            _blogs = await BlogService.GetBlogsAsync();
        }
        catch (Exception ex)
        {
            _message = "Failed to load blogs: " + ex.Message;
            _messageType = "error";
            _showDialog = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private void CreateNewBlog()
    {
        Navigation.NavigateTo("/admin/blog/create");
    }

    private void ViewBlog(Guid id)
    {
        Navigation.NavigateTo($"/admin/blog/view/{id}");
    }

    private void EditBlog(Guid id)
    {
        Navigation.NavigateTo($"/admin/blog/edit/{id}");
    }

    private void ConfirmDelete(Guid id)
    {
        _blogToDelete = id;
        _message = "Are you sure you want to delete this blog?";
        _messageType = "warning";
        _showCancel = true;
        _showDialog = true;
    }

    private async Task HandleDialogClose(bool result)
    {
        _showDialog = false;
        
        if (result && _blogToDelete.HasValue)
        {
            try
            {
                await BlogService.DeleteBlogAsync(_blogToDelete.Value);
                await LoadBlogs();
                _message = "Blog deleted successfully!";
                _messageType = "success";
                _showCancel = false;
                _showDialog = true;
                _blogToDelete = null;
            }
            catch (Exception ex)
            {
                _message = "Delete failed: " + ex.Message;
                _messageType = "error";
                _showCancel = false;
                _showDialog = true;
            }
        }
        else
        {
            _blogToDelete = null;
            _showCancel = false;
        }
    }
}