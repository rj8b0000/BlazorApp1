@page "/admin/blog/view/{Id:guid}"

@using Portfolio.Admin.Models.Blog
@using Portfolio.Admin.Services
@using BlazorBlueprint.Components

@inject BlogApiService BlogService
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<div class="page-header">
    <div class="page-header-info">
        <div class="breadcrumb">
            <a href="">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/">Blogs</a>
            <span class="breadcrumb-separator">/</span>
            <span>View</span>
        </div>
        <h2 class="page-title">Blog Details</h2>
    </div>
    <div style="display: flex; gap: 1rem;">
        <BbButton Variant="ButtonVariant.Outline" OnClick="GoBack">
            Back to List
        </BbButton>
        <BbButton Variant="ButtonVariant.Default" OnClick="EditBlog">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Edit Blog
        </BbButton>
    </div>
</div>

@if (_loading)
{
    <div class="state-container">
        <div class="spinner"></div>
        <p>Loading blog details...</p>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="state-container">
        <p style="color: var(--destructive);">@_errorMessage</p>
    </div>
}
else if (_blog != null)
{
    <div class="grid gap-6">
        <BbCard>
            <BbCardHeader>
                <div class="flex items-center justify-between">
                    <BbCardTitle>General Information</BbCardTitle>
                    <span class="badge @(_blog.IsPublished ? "badge-success" : "badge-warning")">
                        @(_blog.IsPublished ? "Published" : "Draft")
                    </span>
                </div>
            </BbCardHeader>
            <BbCardContent Class="grid gap-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Title</label>
                        <div class="text-lg font-medium">@_blog.Title</div>
                    </div>
                    
                    <div class="space-y-1">
                        <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Created At</label>
                        <div>@_blog.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</div>
                    </div>

                    <div class="space-y-1 md:col-span-2">
                        <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Short Description</label>
                        <div class="text-muted-foreground">@_blog.ShortDescription</div>
                    </div>
                    
                    <div class="space-y-1 md:col-span-2">
                        <label class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Tags</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var tag in _blog.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="bg-secondary text-secondary-foreground px-2 py-1 rounded text-xs font-medium">
                                    @tag.Trim()
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </BbCardContent>
        </BbCard>

        @if (!string.IsNullOrEmpty(_blog.CoverImageUrl))
        {
            var imgUrl = _blog.CoverImageUrl.StartsWith("http") 
                ? _blog.CoverImageUrl 
                : $"{Configuration["ApiSettings:BaseUrl"]?.TrimEnd('/')}/{_blog.CoverImageUrl.TrimStart('/')}";

            <BbCard>
                <BbCardHeader>
                    <BbCardTitle>Cover Image</BbCardTitle>
                </BbCardHeader>
                <BbCardContent>
                    <img src="@imgUrl" alt="Cover" class="max-w-full rounded-lg border object-cover max-h-[400px] bg-muted w-full" />
                </BbCardContent>
            </BbCard>
        }

        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Content Preview</BbCardTitle>
            </BbCardHeader>
            <BbCardContent>
                <div class="p-6 border rounded-lg bg-card min-h-[200px] prose dark:prose-invert max-w-none">
                    @((MarkupString)_blog.HtmlContent)
                </div>
            </BbCardContent>
        </BbCard>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private BlogResponse _blog;
    private bool _loading = true;
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _blog = await BlogService.GetBlogByIdAsync(Id);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private void EditBlog()
    {
        Navigation.NavigateTo($"/admin/blog/edit/{Id}");
    }
}
